# ─────────────────────────────────────────────────────────────────────────────
# ISMS Web Portal — Environment Variables
# Copy this file to .env and fill in your values.
# .env is never committed to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── Device Registry ───────────────────────────────────────────────────────────
# Protects the /api/devices management endpoints.
# Set to any long random string. If left blank, /api/devices is open (dev mode).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=isms_db

# ── Alert Sync ────────────────────────────────────────────────────────────────
# Collection names (must match portal Settings page values)
READINGS_COL=sensor_readings
ALERTS_COL=alert_acks
# How often to check for new/resolved alerts (milliseconds). Default: 30000
ALERT_INTERVAL=30000

# ── Firebase Authentication ──────────────────────────────────────────────────
# Leave blank or omit to run in dev mode (auth skipped, all pages accessible).
# Get these values from: Firebase Console → Project Settings → Your apps → Web
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
