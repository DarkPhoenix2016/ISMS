# ─────────────────────────────────────────────────────────────────────────────
# ISMS Web Portal — Environment Variables
# Copy this file to .env and fill in your values.
# .env is never committed to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=isms_db

# ── Firebase Authentication ──────────────────────────────────────────────────
# Leave blank or omit to run in dev mode (auth skipped, all pages accessible).
# Get these values from: Firebase Console → Project Settings → Your apps → Web
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
